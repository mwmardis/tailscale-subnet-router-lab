# Copy to .env and fill in your values
# DO NOT commit .env — it is gitignored

# Generate a reusable auth key at: https://login.tailscale.com/admin/settings/keys
# Reusable keys allow the container to re-authenticate after restarts
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TS_ROUTES=192.168.1.0/24 #ip range of the subnet you want to route through tailscale

# Optional: additional tailscale arguments (tags, DNS settings, etc.)
# To enable auto-approval of routes, add --advertise-tags with a tag that has autoApprovers configured
TS_EXTRA_ARGS=--advertise-tags=tag:subnet-router --accept-dns=false